{
  "ConnectionStrings": {
    "NotificationDb": "Server=localhost;Database=HRMS_Notification;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "EmailProvider": {
    "ApiKey": "your-brevo-api-key",
    "FromEmail": "noreply@hrmspro.com",
    "FromName": "HRMS Pro",
    "BaseUrl": "https://api.sendinblue.com/v3"
  },
  "SmsProvider": {
    "AccountSid": "your-twilio-account-sid",
