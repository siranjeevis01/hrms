      "notification-service": "${NOTIFICATION_SERVICE_URL:-https://notification.hrms-pro.com}",
      "report-service": "${REPORT_SERVICE_URL:-https://report.hrms-pro.com}",
      "dashboard-service": "${DASHBOARD_SERVICE_URL:-https://dashboard.hrms-pro.com}",
      "audit-service": "${AUDIT_SERVICE_URL:-https://audit.hrms-pro.com}",
      "project-service": "${PROJECT_SERVICE_URL:-https://project.hrms-pro.com}",
      "training-service": "${TRAINING_SERVICE_URL:-https://training.hrms-pro.com}",
      "performance-service": "${PERFORMANCE_SERVICE_URL:-https://performance.hrms-pro.com}"
    },
    "TimeoutSeconds": 5,
    "RequiredServices": [
      "identity-service",
      "employee-service",
      "organization-service"
    ]
  },

