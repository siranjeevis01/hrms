            "Enabled": true,
            "Path": "/health",
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "HealthyThreshold": 2,
            "UnhealthyThreshold": 3
          },
          "Passive": {
            "Enabled": true,
            "UnhealthyResponseTimeout": "00:00:10"
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30",
          "ActivityTimeout": "00:00:25",
          "Version": "1.1",
          "VersionPolicy": "RequestVersionOrLower",
          "AllowResponseBuffering": true
