{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.ReverseProxy": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Properties": {
      "Application": "HRMS.ApiGateway"
    }
  },

  "Jwt": {
    "Authority": "https://identity.hrms-pro.com",
    "Audience": "hrms-api",
    "Issuer": "https://identity.hrms-pro.com",
    "RequireHttps": true
  },

  "Cors": {
    "AllowedOrigins": [
      "https://hrms-pro.com",
      "https://admin.hrms-pro.com",
      "https://portal.hrms-pro.com"
    ]
  },

  "RateLimiting": {
    "Global": {
      "PermitLimit": 200,
      "WindowSeconds": 60,
      "QueueLimit": 10
    }
  },

  "Seq": {
    "ServerUrl": "http://localhost:5341",
    "ApiKey": ""
  },

  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317",
    "ServiceName": "HRMS.ApiGateway"
  },

  "HealthChecks": {
    "ServiceEndpoints": {
      "identity-service": "${IDENTITY_SERVICE_URL:-https://identity.hrms-pro.com}",
      "organization-service": "${ORGANIZATION_SERVICE_URL:-https://organization.hrms-pro.com}",
      "employee-service": "${EMPLOYEE_SERVICE_URL:-https://employee.hrms-pro.com}",
