# ============================================
# HRMS Pro - Environment Configuration
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env
# ============================================

# ============================================
# General Settings
# ============================================
TZ=UTC
BUILD_VERSION=1.0.0
BUILD_DATE=2024-01-01T00:00:00Z
COMPOSE_PROJECT_NAME=hrms-pro

# ============================================
# Application Settings
# ============================================
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# ============================================
# PostgreSQL Database (Supabase for free tier)
# ============================================
SUPABASE_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DATABASE=postgres
SUPABASE_USERNAME=postgres.your-project-ref
SUPABASE_PASSWORD=your-supabase-password
SUPABASE_CONNECTION_STRING=Host=${SUPABASE_HOST};Port=${SUPABASE_PORT};Database=${SUPABASE_DATABASE};Username=${SUPABASE_USERNAME};Password=${SUPABASE_PASSWORD};SSL Mode=Require;Trust Server Certificate=true

# ============================================
# MySQL Database (for local development)
# ============================================
MYSQL_ROOT_PASSWORD=Root@123456
MYSQL_USER=hrms_admin
MYSQL_PASSWORD=Hrms@123456
MYSQL_DATABASE=hrms_identity

# ============================================
# Redis Cache (Upstash for free tier)
# ============================================
REDIS_CONNECTION_STRING=default-red-12345.ap-southeast-1-1.ec2.cloud.redislabs.com:16379,password=your-upstash-password,ssl=True,abortConnect=false
REDIS_PASSWORD=Redis@123456

# ============================================
# RabbitMQ Message Broker (CloudAMQP for free tier)
# ============================================
RABBITMQ_HOSTNAME=your-rabbitmq.cloudamqp.com
RABBITMQ_PORT=5672
RABBITMQ_USER=your-cloudamqp-user
RABBITMQ_PASSWORD=your-cloudamqp-password
RABBITMQ_VHOST=your-vhost

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=YourSuperSecretKeyHereMustBeAtLeast32Characters!
JWT_ISSUER=HRMS-Pro
JWT_AUDIENCE=HRMS-Pro-Users
JWT_EXPIRY_MINUTES=60

# ============================================
# API Configuration
# ============================================
API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200

# ============================================
# SMTP Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_ENABLE_SSL=true

# ============================================
# Firebase Cloud Messaging (Push Notifications)
# ============================================
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# ============================================
# Logging
# ============================================
LOG_LEVEL=Information

# ============================================
# Docker Registry (for CI/CD)
# ============================================
DOCKER_REGISTRY=ghcr.io
DOCKER_REGISTRY_USERNAME=your-github-username
DOCKER_REGISTRY_PASSWORD=your-github-token

# ============================================
# Deployment Environment
# ============================================
DEPLOY_ENV=development
RENDER_API_KEY=your-render-api-key
RENDER_SERVICE_ID=your-render-backend-service-id
RENDER_STATIC_SITE_ID=your-render-frontend-site-id
RAILWAY_TOKEN=your-railway-token
FIREBASE_TOKEN=your-firebase-token
