# ============================================
# HRMS Pro - Environment Configuration
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env
# ============================================

# ============================================
# General Settings
# ============================================
TZ=UTC
BUILD_VERSION=1.0.0
BUILD_DATE=2024-01-01T00:00:00Z
COMPOSE_PROJECT_NAME=hrms-pro

# ============================================
# Application Settings
# ============================================
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# ============================================
# PostgreSQL Database (Supabase for free tier)
# ============================================
SUPABASE_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DATABASE=postgres
SUPABASE_USERNAME=postgres.your-project-ref
SUPABASE_PASSWORD=<CHANGE_ME>
SUPABASE_CONNECTION_STRING=Host=${SUPABASE_HOST};Port=${SUPABASE_PORT};Database=${SUPABASE_DATABASE};Username=${SUPABASE_USERNAME};Password=${SUPABASE_PASSWORD};SSL Mode=Require;Trust Server Certificate=true

# ============================================
# PostgreSQL Database (Monolith)
# ============================================
POSTGRES_DB=hrms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGE_ME>

# ============================================
# MySQL Database (for local development)
# ============================================
MYSQL_ROOT_PASSWORD=<CHANGE_ME>
MYSQL_USER=hrms_admin
MYSQL_PASSWORD=<CHANGE_ME>
MYSQL_DATABASE=hrms_identity

# ============================================
# Redis Cache (Upstash for free tier)
# ============================================
REDIS_CONNECTION_STRING=default-red-12345.ap-southeast-1-1.ec2.cloud.redislabs.com:16379,password=<CHANGE_ME>,ssl=True,abortConnect=false
REDIS_PASSWORD=<CHANGE_ME>

# ============================================
# RabbitMQ Message Broker (CloudAMQP for free tier)
# ============================================
RABBITMQ_HOSTNAME=your-rabbitmq.cloudamqp.com
RABBITMQ_PORT=5672
RABBITMQ_USER=<CHANGE_ME>
RABBITMQ_PASSWORD=<CHANGE_ME>
RABBITMQ_VHOST=<CHANGE_ME>

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=<CHANGE_ME>
JWT_ISSUER=HRMS-Pro
JWT_AUDIENCE=HRMS-Pro-Users
JWT_EXPIRY_MINUTES=60

# ============================================
# API Configuration
# ============================================
API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200

# ============================================
# Microservice URLs
# ============================================
CHAT_SERVICE_URL=http://localhost:5001
TRAVEL_SERVICE_URL=http://localhost:5002
EXPENSE_SERVICE_URL=http://localhost:5003
HELPDESK_SERVICE_URL=http://localhost:5004
DOCUMENT_SERVICE_URL=http://localhost:5005
WORKFLOW_SERVICE_URL=http://localhost:5006

# ============================================
# Elasticsearch
# ============================================
ELASTICSEARCH_USERNAME=<CHANGE_ME>
ELASTICSEARCH_PASSWORD=<CHANGE_ME>

# ============================================
# SMTP Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=<CHANGE_ME>
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_ENABLE_SSL=true

# ============================================
# Firebase Cloud Messaging (Push Notifications)
# ============================================
FCM_SERVER_KEY=<CHANGE_ME>
FCM_SENDER_ID=<CHANGE_ME>

# ============================================
# Logging
# ============================================
LOG_LEVEL=Information

# ============================================
# Docker Registry (for CI/CD)
# ============================================
DOCKER_REGISTRY=ghcr.io
DOCKER_REGISTRY_USERNAME=<CHANGE_ME>
DOCKER_REGISTRY_PASSWORD=<CHANGE_ME>

# ============================================
# Deployment Environment
# ============================================
DEPLOY_ENV=development
RENDER_API_KEY=<CHANGE_ME>
RENDER_SERVICE_ID=<CHANGE_ME>
RENDER_STATIC_SITE_ID=<CHANGE_ME>
RAILWAY_TOKEN=<CHANGE_ME>
FIREBASE_TOKEN=<CHANGE_ME>
